<mxfile host="app.diagrams.net">
  <diagram name="Sync Workflow" id="sync-flow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Trigger -->
        <mxCell id="10" value="Push to main&#xa;(src/content/docs/**)&#xa;or manual trigger" style="shape=ellipse;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="340" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- GitHub Actions -->
        <mxCell id="20" value="GitHub Actions&#xa;runs sync.yml" style="shape=rect;rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="320" y="350" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- sync.py -->
        <mxCell id="30" value="sync.py" style="shape=rect;rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="350" width="160" height="80" as="geometry"/>
        </mxCell>

        <!-- Fetch State -->
        <mxCell id="40" value="fetch_state()&#xa;Query Open WebUI for&#xa;existing files + hashes" style="shape=rect;rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="820" y="200" width="200" height="70" as="geometry"/>
        </mxCell>

        <!-- Scan Local -->
        <mxCell id="50" value="scan_local_files()&#xa;Walk DOCS_DIR for&#xa;all .md files" style="shape=rect;rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="820" y="500" width="200" height="70" as="geometry"/>
        </mxCell>

        <!-- Compare -->
        <mxCell id="60" value="Compare&#xa;local hash vs.&#xa;remote hash" style="shape=rhombus;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1100" y="320" width="150" height="140" as="geometry"/>
        </mxCell>

        <!-- New -->
        <mxCell id="70" value="New file&#xa;→ upload + add&#xa;to Knowledge Base" style="shape=rect;rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1340" y="180" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- Changed -->
        <mxCell id="80" value="Hash changed&#xa;→ remove old,&#xa;upload new version" style="shape=rect;rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1340" y="280" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- Unchanged -->
        <mxCell id="90" value="Hash matches&#xa;→ skip" style="shape=rect;rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1340" y="380" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- Deleted -->
        <mxCell id="100" value="Not on disk&#xa;→ remove from&#xa;Knowledge Base" style="shape=rect;rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1340" y="480" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- Open WebUI -->
        <mxCell id="110" value="Open WebUI&#xa;chunks, embeds,&#xa;stores vectors" style="shape=cylinder3;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;size=10;" vertex="1" parent="1">
          <mxGeometry x="1340" y="600" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- Arrows -->
        <mxCell id="a1" edge="1" source="10" target="20" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a2" edge="1" source="20" target="30" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a3" edge="1" source="30" target="40" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a4" edge="1" source="30" target="50" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a5" edge="1" source="40" target="60" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a6" edge="1" source="50" target="60" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a7" value="new" style="fontSize=10;" edge="1" source="60" target="70" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a8" value="changed" style="fontSize=10;" edge="1" source="60" target="80" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a9" value="unchanged" style="fontSize=10;" edge="1" source="60" target="90" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a10" value="deleted" style="fontSize=10;" edge="1" source="60" target="100" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a11" edge="1" source="70" target="110" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a12" edge="1" source="80" target="110" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
