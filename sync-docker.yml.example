# sync.yml (for the customer repo)
# Drop this file into the customer's .github/workflows/ directory.
name: Sync Docs to OpenWebUI

on:
  # Trigger on every push to main that touches markdown files inside the docs folder.
  push:
    branches: [main]
    paths:
      - 'src/content/docs/**'
  # Allow manual trigger from the GitHub Actions UI (useful for initial bulk upload).
  workflow_dispatch:

jobs:
  sync:
    runs-on: ubuntu-latest
    steps:
      # Check out the customer repo so the docs folder is available to mount.
      - uses: actions/checkout@v4

      # Run the sync container.
      # The customer's docs folder is mounted into the container at /docs.
      # DOCS_DIR tells sync.py where to find the markdown files inside the container.
      - name: Sync to OpenWebUI
        run: |
          docker run --rm \
            -e OPEN_WEBUI_API_URL="${{ secrets.OPEN_WEBUI_API_URL }}" \
            -e OPEN_WEBUI_API_KEY="${{ secrets.OPEN_WEBUI_API_KEY }}" \
            -e KNOWLEDGE_ID="${{ secrets.KNOWLEDGE_ID }}" \
            -e DOCS_DIR="/docs" \
            -v "${{ github.workspace }}/src/content/docs:/docs" \
            ghcr.io/sportidentgmbh/embedding-pipeline:v1.0.0
